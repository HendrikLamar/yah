# Copy to .env.dkb.local and fill with your DKB FinTS credentials.
# USER_ID and CUSTOMER_ID are often the same for DKB, but customer_id can be overridden if needed.
DKB_FINTS_BANK_IDENTIFIER=12030000
DKB_FINTS_SERVER=https://banking-dkb.s-fints-pt-dkb.de/fints30
DKB_FINTS_USER_ID=
DKB_FINTS_CUSTOMER_ID=
DKB_FINTS_PIN=
DKB_FINTS_PRODUCT_ID=household-finance-local-test
DKB_FINTS_PRODUCT_VERSION=0.1.0
DKB_FINTS_DAYS=30
