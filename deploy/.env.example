############################################################
# Self-hosted yah — environment template.
#
# DO NOT commit a filled-in copy. Generate real secrets with:
#   bash deploy/gen-secrets.sh > deploy/.env
# then edit the domain + GoCardless values. deploy/.env is gitignored.
############################################################

############
# Domain & public URLs
############
APP_DOMAIN=yah.example.com
CADDY_EMAIL=admin@example.com
# Browser + server Supabase client target (the api subdomain, fronted by Caddy):
NEXT_PUBLIC_SUPABASE_URL=https://api.yah.example.com
NEXT_PUBLIC_APP_URL=https://yah.example.com
SUPABASE_PUBLIC_URL=https://api.yah.example.com
API_EXTERNAL_URL=https://api.yah.example.com
SITE_URL=https://yah.example.com
ADDITIONAL_REDIRECT_URLS=https://yah.example.com

############
# GoCardless Bank Account Data (PSD2 aggregator)
############
GOCARDLESS_SECRET_ID=your-secret-id
GOCARDLESS_SECRET_KEY=your-secret-key
GOCARDLESS_BASE_URL=https://bankaccountdata.gocardless.com/api/v2

############
# Secrets — generate with deploy/gen-secrets.sh (placeholders only here)
############
POSTGRES_PASSWORD=generate-me
JWT_SECRET=generate-me-at-least-32-chars
# Minted from JWT_SECRET as HS256 JWTs (role=anon / role=service_role):
ANON_KEY=generate-me
SERVICE_ROLE_KEY=generate-me
SECRET_KEY_BASE=generate-me-64-chars
PG_META_CRYPTO_KEY=generate-me-32-chars
CRON_SECRET=generate-me
# App: encrypts stored bank tokens at rest (32-byte base64).
TOKEN_ENCRYPTION_KEY=generate-me-32-byte-base64

############
# Dashboard (Studio) basic-auth — Studio is SSH-tunnel only
############
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=generate-me

############
# Postgres
############
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# Auth (email/password, autoconfirm — no SMTP)
############
DISABLE_SIGNUP=false
JWT_EXPIRY=3600
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=localhost
SMTP_PORT=2500
SMTP_USER=fake
SMTP_PASS=fake
SMTP_SENDER_NAME=yah
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

############
# Studio / Kong / PostgREST
############
STUDIO_DEFAULT_ORGANIZATION=yah
STUDIO_DEFAULT_PROJECT=yah
STUDIO_HOST_PORT=8001
OPENAI_API_KEY=
KONG_HTTP_PORT=8000
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

############
# Storage / imgproxy / functions (kept at defaults; app does not use Storage)
############
GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=
IMGPROXY_AUTO_WEBP=true
FUNCTIONS_VERIFY_JWT=false

############
# Optional new-style opaque / asymmetric keys (unused — legacy HS256 path).
############
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=
JWT_KEYS=
JWT_JWKS=
