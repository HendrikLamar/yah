# --- Supabase ---
# Local dev uses the Supabase CLI stack (`supabase start`). For the self-hosted
# production stack see deploy/.env.example + deploy/README.md (the URL points at
# the api subdomain, e.g. https://api.yah.example.com).
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, NEVER expose to client

# --- Enable Banking (PSD2 aggregator) ---
# Register an application at https://enablebanking.com/cp -> copy the app id
# and the RSA private key. The key goes in as base64 of the full PEM:
#   base64 < private.pem | tr -d '\n'
ENABLE_BANKING_APPLICATION_ID=your-application-id
ENABLE_BANKING_PRIVATE_KEY_B64=base64-of-private-key-pem
# Optional override, defaults to the production host
# ENABLE_BANKING_BASE_URL=https://api.enablebanking.com

# Optional, server-side only: base URL the SERVER uses to reach Supabase.
# Unset in dev (falls back to NEXT_PUBLIC_SUPABASE_URL). In production it's
# http://kong:8000 so server-side calls skip the public edge.
# SUPABASE_INTERNAL_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used to encrypt stored bank tokens at rest (32-byte base64). Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64
# Secret guarding the cron endpoint (the in-stack cron container sends this as Bearer)
CRON_SECRET=replace-with-random-string
